    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "prettier": "^3.9.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5"
