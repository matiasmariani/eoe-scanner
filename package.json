    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "framer-motion": "^12.42.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.400.0",
    "next": "^15.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-kawaii": "^1.6.0",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
